<mxfile host="app.diagrams.net" agent="hand" version="24.7.0">
  <diagram id="cast-pipeline" name="CAST">
    <mxGraphModel dx="1422" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1450" pageHeight="720" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="CAST — Conditional Activation Steering" style="text;html=1;fontSize=22;fontStyle=1;align=left;verticalAlign=middle;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1330" height="36" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Learn a per-behavior &quot;is this prompt on-topic?&quot; detector, then only steer at the positions where it fires. Off-target prompts pass through untouched." style="text;html=1;fontSize=13;align=left;verticalAlign=middle;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="58" width="1330" height="24" as="geometry" />
        </mxCell>

        <!-- PHASE A container -->
        <mxCell id="cA" value="PHASE A — Learn the condition&#160;&#160;(offline, once per behavior b)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#82b366;dashed=1;verticalAlign=top;fontStyle=1;fontSize=13;align=center;spacingTop=6;fontColor=#4a7a3a;" vertex="1" parent="1">
          <mxGeometry x="40" y="110" width="680" height="510" as="geometry" />
        </mxCell>

        <mxCell id="pos" value="&lt;b&gt;Positive prompts&lt;/b&gt;&lt;br&gt;own &lt;i&gt;generate&lt;/i&gt; set for b&lt;br&gt;(N = 100)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Helvetica;fontSize=12;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="70" y="160" width="290" height="70" as="geometry" />
        </mxCell>
        <mxCell id="neg" value="&lt;b&gt;Negative prompts&lt;/b&gt;&lt;br&gt;pooled from the other 15 behaviors&lt;br&gt;(N = 100)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Helvetica;fontSize=12;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="400" y="160" width="290" height="70" as="geometry" />
        </mxCell>

        <mxCell id="acts" value="Run the model; take the &lt;b&gt;last-token activation&lt;/b&gt; at target layer L&lt;br&gt;&#160;&#160;h&#8314; (positives)&#160;&#160;&#160;&#160;&#160;h&#8315; (negatives)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontFamily=Helvetica;fontSize=12;align=center;" vertex="1" parent="1">
          <mxGeometry x="70" y="265" width="620" height="55" as="geometry" />
        </mxCell>

        <mxCell id="dir" value="&lt;b&gt;Condition direction&lt;/b&gt;&#10;c&#7495; = normalize( mean(h&#8314;) &#8722; mean(h&#8315;) )" style="whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontFamily=Courier New;fontSize=12;align=center;" vertex="1" parent="1">
          <mxGeometry x="70" y="350" width="620" height="55" as="geometry" />
        </mxCell>

        <mxCell id="f1grid" value="&lt;b&gt;F1-tuned threshold&lt;/b&gt;&#160;&#160;score = cos(h, c&#7495;)&#10;over candidate &#964;:&#160;&#160;TP = #(pos &#8805; &#964;),&#160;FP = #(neg &#8805; &#964;),&#160;FN = #(pos &#60; &#964;)&#10;&#9658; &#964;* = argmax&#7506; F1(&#964;)" style="whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontFamily=Courier New;fontSize=12;align=left;spacingLeft=8;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="70" y="430" width="620" height="100" as="geometry" />
        </mxCell>

        <mxCell id="condout" value="&lt;b&gt;Condition for behavior b:&#160;&#160;( c&#7495; ,&#160; &#964;* )&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontFamily=Helvetica;fontSize=13;align=center;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="70" y="555" width="620" height="45" as="geometry" />
        </mxCell>

        <!-- PHASE B container -->
        <mxCell id="cB" value="PHASE B — Gated steering&#160;&#160;(inference, at target layer L)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#b85450;dashed=1;verticalAlign=top;fontStyle=1;fontSize=13;align=center;spacingTop=6;fontColor=#9c3b37;" vertex="1" parent="1">
          <mxGeometry x="770" y="110" width="600" height="510" as="geometry" />
        </mxCell>

        <mxCell id="hin" value="&lt;b&gt;Hidden state h&lt;/b&gt; at each token position (layer L)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Helvetica;fontSize=12;align=center;" vertex="1" parent="1">
          <mxGeometry x="800" y="165" width="540" height="50" as="geometry" />
        </mxCell>

        <mxCell id="gate" value="&lt;b&gt;Gate (per position)&lt;/b&gt;&#10;g = 1[ cos(h, c&#7495;) &#8805; &#964;* ]&#160;&#160;&#8712; {0, 1}" style="whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontFamily=Courier New;fontSize=13;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="800" y="255" width="540" height="70" as="geometry" />
        </mxCell>

        <mxCell id="apply" value="&lt;b&gt;Apply only where the gate fires&lt;/b&gt;&#10;h &#8592; h + g · ( s&#7495; · &#945; · v&#7495; )&#160;&#160;&#160;&#160;&#160;(CAA shown)&#10;&#10;DIM-suppress &#8594; g · (&#8722;&#945;(h·d)d) ;&#160;&#160;ACE &#8594; g · &#916;_ace&#10;single-layer gating at L for every method" style="whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontFamily=Courier New;fontSize=12;align=left;spacingLeft=8;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="800" y="365" width="540" height="120" as="geometry" />
        </mxCell>

        <mxCell id="bout" value="&lt;b&gt;Conditionally-steered output&lt;/b&gt;&lt;br&gt;on-topic positions are steered;&lt;br&gt;off-target positions (g = 0) are left exactly as-is" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontFamily=Helvetica;fontSize=12;align=center;" vertex="1" parent="1">
          <mxGeometry x="800" y="520" width="540" height="75" as="geometry" />
        </mxCell>

        <!-- EDGES phase A -->
        <mxCell id="ea1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#555555;exitX=0.5;exitY=1;entryX=0.25;entryY=0;" edge="1" parent="1" source="pos" target="acts">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ea2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#555555;exitX=0.5;exitY=1;entryX=0.75;entryY=0;" edge="1" parent="1" source="neg" target="acts">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ea3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#555555;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="acts" target="dir">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ea4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#555555;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="dir" target="f1grid">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ea5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#555555;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="f1grid" target="condout">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- bridge A -> B -->
        <mxCell id="bridge" value="condition feeds the gate" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#d6b656;strokeWidth=2;fontSize=11;exitX=1;exitY=0.5;entryX=0.5;entryY=1;" edge="1" parent="1" source="condout" target="gate">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- EDGES phase B -->
        <mxCell id="eb1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#555555;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="hin" target="gate">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="eb2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#555555;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="gate" target="apply">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="eb3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#9673a6;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="apply" target="bout">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- LEGEND -->
        <mxCell id="legend" value="&lt;b&gt;Legend&lt;/b&gt;&#160;&#160;&#9632; data (blue)&#160;&#160;&#9632; compute (green)&#160;&#160;&#9632; formula (grey)&#160;&#160;&#9632; learned condition (yellow)&#160;&#160;&#9632; gate (red)&#160;&#160;&#9632; output (purple)" style="text;html=1;fontSize=11;align=left;verticalAlign=middle;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="635" width="1330" height="24" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
