<mxfile host="app.diagrams.net" agent="hand" version="24.7.0">
  <diagram id="disp-pipeline" name="DISP">
    <mxGraphModel dx="1422" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1450" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="DISP — Directional Interference Suppression for steering vectors" style="text;html=1;fontSize=22;fontStyle=1;align=left;verticalAlign=middle;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1330" height="36" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="For each target behavior i: strip the directions it shares with the other behaviors out of its steering vector, so the on-target effect survives but cross-behavior side-effects shrink." style="text;html=1;fontSize=13;align=left;verticalAlign=middle;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="58" width="1330" height="24" as="geometry" />
        </mxCell>

        <!-- INPUTS -->
        <mxCell id="in1" value="&lt;b&gt;Steering vectors&lt;/b&gt;&lt;br&gt;V = { v&#8321; … v&#8344; }&lt;br&gt;method-native (CAA / DIM / ACE)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Helvetica;fontSize=12;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="150" width="250" height="70" as="geometry" />
        </mxCell>
        <mxCell id="in2" value="&lt;b&gt;Cross-effect matrix&lt;/b&gt;&lt;br&gt;pct[i,j]  (16&#215;16)&lt;br&gt;steering-effect % from the&lt;br&gt;baseline (unsteered-delta) run" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Helvetica;fontSize=12;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="235" width="250" height="80" as="geometry" />
        </mxCell>
        <mxCell id="in3" value="&lt;b&gt;Desired directions&lt;/b&gt;&lt;br&gt;signs s&#7522; (increase / decrease)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Helvetica;fontSize=12;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="330" width="250" height="55" as="geometry" />
        </mxCell>

        <!-- STAGE 1 container -->
        <mxCell id="c1" value="STAGE 1 — Bidirectional interference weighting&#160;&#160;(&#955;)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#6c8ebf;dashed=1;verticalAlign=top;fontStyle=1;fontSize=13;align=center;spacingTop=6;fontColor=#3b5b8c;" vertex="1" parent="1">
          <mxGeometry x="330" y="110" width="330" height="320" as="geometry" />
        </mxCell>
        <mxCell id="f1" value="out&#7468; = |pct[i,j]| / max&#11388; |pct[i,j']|&#160;&#160;(i disturbs j)&#10;in&#7468;&#160; = |pct[j,i]| / max&#7522;&#160;|pct[i',i]|&#160;&#160;(j disturbs i)&#10;&#10;&#9658; w&#7468; = &#955;·out&#7468; + (1&#8722;&#955;)·in&#7468;&#160;&#160;&#160;(j &#8800; i)" style="whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontFamily=Courier New;fontSize=12;align=left;spacingLeft=8;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="350" y="175" width="290" height="150" as="geometry" />
        </mxCell>
        <mxCell id="g1" value="&#955; &#8712; {0.5, 0.6, …, 1.0}&lt;br&gt;&lt;b&gt;T1&lt;/b&gt; grid-searches &#955; (with &#945;=1 hard, &#964;=0.90)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontFamily=Helvetica;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="350" y="340" width="290" height="75" as="geometry" />
        </mxCell>

        <!-- STAGE 2 container -->
        <mxCell id="c2" value="STAGE 2 — Weighted-SVD interference basis&#160;&#160;(&#964;)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#82b366;dashed=1;verticalAlign=top;fontStyle=1;fontSize=13;align=center;spacingTop=6;fontColor=#4a7a3a;" vertex="1" parent="1">
          <mxGeometry x="690" y="110" width="330" height="320" as="geometry" />
        </mxCell>
        <mxCell id="f2" value="weight the other vectors, stack them:&#10;&#160;&#160;I = diag(w) · V&#8331;&#11388;&#8800;&#7522;&#8323;&#10;&#10;SVD(I) = U &#931; V&#7488;&#10;keep top-k right dirs d&#8321;…d&#8342;&#10;with cumulative energy &#8805; &#964;" style="whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontFamily=Courier New;fontSize=12;align=left;spacingLeft=8;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="710" y="175" width="290" height="150" as="geometry" />
        </mxCell>
        <mxCell id="g2" value="&#964; &#8712; {0.50, …, 0.99}, default 0.90&lt;br&gt;&lt;b&gt;T3&lt;/b&gt; grid-searches &#964; (at best &#955; and &#945; strategy)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontFamily=Helvetica;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="710" y="340" width="290" height="75" as="geometry" />
        </mxCell>

        <!-- STAGE 3 container -->
        <mxCell id="c3" value="STAGE 3 — Soft projection / removal&#160;&#160;(&#945;)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#d79b00;dashed=1;verticalAlign=top;fontStyle=1;fontSize=13;align=center;spacingTop=6;fontColor=#a5700a;" vertex="1" parent="1">
          <mxGeometry x="1050" y="110" width="330" height="320" as="geometry" />
        </mxCell>
        <mxCell id="f3" value="&#9658; v&#7522;' = v&#7522; &#8722; &#931;&#8342; &#945;&#8342; (v&#7522;·d&#8342;) d&#8342;&#10;&#10;soft removal of the shared&#10;interference directions&#10;(&#945;&#8342; = 1 &#8658; hard projection)" style="whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontFamily=Courier New;fontSize=12;align=left;spacingLeft=8;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="1070" y="175" width="290" height="150" as="geometry" />
        </mxCell>
        <mxCell id="g3" value="&#945;&#8342; &#8712; {0.0, 0.05, …, 1.5} per direction&lt;br&gt;&lt;b&gt;T2&lt;/b&gt; picks &#945;: keep |self| &#8805; 0.85·|self&#8320;|,&lt;br&gt;then minimize side-effect SE%" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontFamily=Helvetica;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1070" y="340" width="290" height="75" as="geometry" />
        </mxCell>

        <!-- OBJECTIVE -->
        <mxCell id="obj" value="&lt;b&gt;Objective&lt;/b&gt;&lt;br&gt;SE% = &#931;&#8331;&#7522;&#8800;&#11388;&#8323; |pct[i,j]|&lt;br&gt;minimize side-effects subject to the self-effect floor" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontFamily=Helvetica;fontSize=12;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="690" y="470" width="330" height="90" as="geometry" />
        </mxCell>

        <!-- OUTPUT -->
        <mxCell id="out" value="&lt;b&gt;DISP-corrected vector&#160;v&#7522;'&lt;/b&gt;&lt;br&gt;inject at the target layer (ActAdd)&lt;br&gt;&#8594; on-target (self) effect preserved&lt;br&gt;&#8594; cross-behavior side-effects suppressed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontFamily=Helvetica;fontSize=12;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1050" y="470" width="330" height="90" as="geometry" />
        </mxCell>

        <!-- TUNING BANNER -->
        <mxCell id="tune" value="Tuning order — each task feeds its best value forward:&#160;&#160;&#160;&#160;T1 grid &#955;&#160;&#160;&#8594;&#160;&#160;T2 grid &#945;&#8342; (self-floor 0.85, min SE%)&#160;&#160;&#8594;&#160;&#160;T3 grid &#964; (SVD energy)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f0f0;strokeColor=#999999;fontFamily=Helvetica;fontSize=12;fontStyle=2;align=center;" vertex="1" parent="1">
          <mxGeometry x="330" y="600" width="1050" height="45" as="geometry" />
        </mxCell>

        <!-- LEGEND -->
        <mxCell id="legend" value="&lt;b&gt;Legend&lt;/b&gt;&lt;br&gt;&#9632; input data&#160;&#160;(blue)&lt;br&gt;&#9632; formula / transform&#160;&#160;(grey)&lt;br&gt;&#9632; grid-search choice&#160;&#160;(orange)&lt;br&gt;&#9632; objective / constraint&#160;&#160;(yellow)&lt;br&gt;&#9632; output vector&#160;&#160;(purple)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cccccc;fontFamily=Helvetica;fontSize=11;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="440" width="250" height="160" as="geometry" />
        </mxCell>

        <!-- EDGES -->
        <mxCell id="e_in1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#6c8ebf;fontSize=10;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="in1" target="f1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_in2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#6c8ebf;fontSize=10;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="in2" target="f1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_in3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#6c8ebf;dashed=1;fontSize=10;" edge="1" parent="1" source="in3" target="f3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e12" value="weights w&#7468;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#555555;fontSize=11;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="f1" target="f2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e23" value="basis d&#8321;…d&#8342;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#555555;fontSize=11;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="f2" target="f3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3o" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#9673a6;fontSize=11;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="f3" target="out">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="eobj" value="guides &#945;-search" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;dashed=1;strokeColor=#d6b656;fontSize=10;exitX=0.5;exitY=0;entryX=0.5;entryY=1;" edge="1" parent="1" source="obj" target="g3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
