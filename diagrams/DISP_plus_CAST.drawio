<mxfile host="app.diagrams.net" agent="hand" version="24.7.0">
  <diagram id="disp-cast" name="DISP+CAST">
    <mxGraphModel dx="1422" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1450" pageHeight="720" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="DISP + CAST — corrected vectors, conditionally applied" style="text;html=1;fontSize=22;fontStyle=1;align=left;verticalAlign=middle;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1330" height="36" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Two orthogonal defenses combine (baseline task T6): DISP cleans the steering vector in &lt;b&gt;vector space&lt;/b&gt;, CAST limits &lt;b&gt;when&lt;/b&gt; it fires in prompt space. Together: minimal side-effects, preserved self-effect." style="text;html=1;fontSize=13;align=left;verticalAlign=middle;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="58" width="1330" height="24" as="geometry" />
        </mxCell>

        <!-- PILLAR 1: DISP -->
        <mxCell id="p1" value="PILLAR 1 — DISP&#160;&#160;(clean the vector)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#6c8ebf;dashed=1;verticalAlign=top;fontStyle=1;fontSize=13;align=center;spacingTop=6;fontColor=#3b5b8c;" vertex="1" parent="1">
          <mxGeometry x="40" y="110" width="560" height="340" as="geometry" />
        </mxCell>
        <mxCell id="d_in" value="&lt;b&gt;Original method vector&lt;/b&gt; v&#7495;&lt;br&gt;+ cross-effect matrix pct[i,j]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Helvetica;fontSize=12;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="70" y="160" width="500" height="55" as="geometry" />
        </mxCell>
        <mxCell id="d_proc" value="&lt;b&gt;DISP pipeline&lt;/b&gt;&#160;&#160;(see DISP diagram)&#10;&#955;:&#160; bidirectional interference weights w&#7468;&#10;&#964;:&#160; weighted-SVD basis d&#8321;…d&#8342; (energy &#8805; &#964;)&#10;&#945;:&#160; v&#7495;' = v&#7495; &#8722; &#931;&#8342; &#945;&#8342;(v&#7495;·d&#8342;)d&#8342;" style="whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontFamily=Courier New;fontSize=12;align=left;spacingLeft=8;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="70" y="245" width="500" height="105" as="geometry" />
        </mxCell>
        <mxCell id="d_hp" value="T6 uses the &lt;b&gt;DISP-best (T3)&lt;/b&gt; setting: best &#955;, per-target &#964; and &#945;&#8342; restored from the real-inference sweep&#160;(real_sweep_&lt;model&gt;.json)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontFamily=Helvetica;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="70" y="370" width="500" height="60" as="geometry" />
        </mxCell>
        <mxCell id="d_out" value="&lt;b&gt;Corrected vector&#160;v&#7495;'&lt;/b&gt;&#160;&#160;(shared interference directions removed)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontFamily=Helvetica;fontSize=12;align=center;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="640" y="300" width="170" height="80" as="geometry" />
        </mxCell>

        <!-- PILLAR 2: CAST -->
        <mxCell id="p2" value="PILLAR 2 — CAST&#160;&#160;(gate when it fires)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#b85450;dashed=1;verticalAlign=top;fontStyle=1;fontSize=13;align=center;spacingTop=6;fontColor=#9c3b37;" vertex="1" parent="1">
          <mxGeometry x="850" y="110" width="540" height="340" as="geometry" />
        </mxCell>
        <mxCell id="c_in" value="&lt;b&gt;Positive&lt;/b&gt; (own prompts) vs &lt;b&gt;Negative&lt;/b&gt; (pooled others)&lt;br&gt;last-token activations at layer L" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Helvetica;fontSize=12;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="880" y="160" width="480" height="55" as="geometry" />
        </mxCell>
        <mxCell id="c_proc" value="&lt;b&gt;CAST condition&lt;/b&gt;&#160;&#160;(see CAST diagram)&#10;c&#7495; = normalize( mean(h&#8314;) &#8722; mean(h&#8315;) )&#10;&#964;* = argmax&#7506; F1 over cos(h, c&#7495;)" style="whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontFamily=Courier New;fontSize=12;align=left;spacingLeft=8;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="880" y="245" width="480" height="105" as="geometry" />
        </mxCell>
        <mxCell id="c_out" value="&lt;b&gt;Gate ( c&#7495; , &#964;* )&lt;/b&gt;&#160;&#160;fires only on behavior-b prompts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontFamily=Helvetica;fontSize=12;align=center;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="880" y="375" width="480" height="50" as="geometry" />
        </mxCell>

        <!-- COMBINE -->
        <mxCell id="combine" value="&lt;b&gt;Inference at target layer L — per token position&lt;/b&gt;&#10;&#10;g = 1[ cos(h, c&#7495;) &#8805; &#964;* ]&#160;&#160;&#160;&#160;&#8592; CAST decides &lt;i&gt;where&lt;/i&gt;&#10;h &#8592; h + g · ( s&#7495; · &#945; · &lt;b&gt;v&#7495;'&lt;/b&gt; )&#160;&#160;&#8592; DISP decides &lt;i&gt;what&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontFamily=Courier New;fontSize=13;align=left;spacingLeft=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="430" y="500" width="560" height="120" as="geometry" />
        </mxCell>

        <mxCell id="result" value="&lt;b&gt;Result&lt;/b&gt;&lt;br&gt;DISP shrinks cross-behavior leakage&lt;br&gt;baked into the vector;&lt;br&gt;CAST stops it firing on off-target prompts.&lt;br&gt;&#8594; lowest side-effects, self-effect intact" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontFamily=Helvetica;fontSize=12;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1050" y="500" width="340" height="120" as="geometry" />
        </mxCell>

        <!-- EDGES pillar 1 -->
        <mxCell id="ed1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#555555;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="d_in" target="d_proc">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ed2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#9673a6;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="d_proc" target="d_out">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- EDGES pillar 2 -->
        <mxCell id="ec1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#555555;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="c_in" target="c_proc">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ec2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#d6b656;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="c_proc" target="c_out">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- merge into combine -->
        <mxCell id="m1" value="v&#7495;'" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#9673a6;strokeWidth=2;fontSize=12;exitX=0.5;exitY=1;entryX=0.25;entryY=0;" edge="1" parent="1" source="d_out" target="combine">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="m2" value="( c&#7495; , &#964;* )" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#d6b656;strokeWidth=2;fontSize=12;exitX=0.5;exitY=1;entryX=0.75;entryY=0;" edge="1" parent="1" source="c_out" target="combine">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="m3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#9673a6;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="combine" target="result">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- LEGEND -->
        <mxCell id="legend" value="&lt;b&gt;Legend&lt;/b&gt;&#160;&#160;&#9632; data (blue)&#160;&#160;&#9632; formula (grey)&#160;&#160;&#9632; hyperparam source (orange)&#160;&#160;&#9632; condition (yellow)&#160;&#160;&#9632; combined inference (green)&#160;&#160;&#9632; output (purple)" style="text;html=1;fontSize=11;align=left;verticalAlign=middle;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="640" width="1350" height="24" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
